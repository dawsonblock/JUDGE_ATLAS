# JudgeTracker Atlas — Local Development Environment
# Copy to .env or use with: set -a && source .env.development && set +a
# These values are DEVELOPMENT-ONLY. Never use in production.

# Database — SQLite by default for zero-config local dev
JTA_DATABASE_URL=sqlite:///./judgetracker.db

# Environment
JTA_APP_ENV=development

# Auto-seed sample data on startup
JTA_AUTO_SEED=true

# CORS
JTA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Admin tokens — placeholder values safe for local dev only
JTA_ADMIN_TOKEN=dev-admin-token-local
JTA_ADMIN_REVIEW_TOKEN=dev-review-token-local

# Admin feature flags — all enabled for local development iteration
JTA_ENABLE_ADMIN_IMPORTS=true
JTA_ENABLE_ADMIN_REVIEW=true
JTA_ENABLE_PUBLIC_EVENT_POST=true

# Rate-limit backend — in-memory (no Redis required locally)
JTA_RATE_LIMIT_BACKEND=memory

# CourtListener — leave token empty to skip live API calls during local dev
JTA_COURTLISTENER_API_TOKEN=
JTA_COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4
JTA_COURTLISTENER_MAX_PAGES=2
JTA_COURTLISTENER_MAX_DOCKETS_PER_RUN=10
JTA_COURTLISTENER_TIMEOUT_SECONDS=30

# Ollama / Source Verification — disabled locally unless you run Ollama
JTA_OLLAMA_ENABLED=false

# Crime feed flags — disabled locally
JTA_STATSCAN_ENABLED=false
JTA_FBI_CRIME_ENABLED=false
JTA_LOCAL_FEEDS_ENABLED=false
JTA_GDELT_ENABLED=false
