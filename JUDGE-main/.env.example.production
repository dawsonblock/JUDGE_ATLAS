# =============================================================================
# JudgeTracker Atlas - Production Environment Configuration
# =============================================================================
# WARNING: This file is a TEMPLATE. Never commit real credentials.
# Copy to .env on your production server and fill in real values.
# =============================================================================

# Application environment (MUST be "production" in production)
JTA_APP_ENV=production

# -----------------------------------------------------------------------------
# Authentication (JWT is the production authority)
# -----------------------------------------------------------------------------
JTA_JWT_AUTH_ENABLED=true
JTA_JWT_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET  # startup exits with error until replaced — generate: python -c 'import secrets; print(secrets.token_urlsafe(48))'
JTA_ENABLE_LEGACY_ADMIN_TOKEN=false
JTA_FIRST_ADMIN_SECRET=REPLACE_WITH_BOOTSTRAP_SECRET  # startup exits with error until replaced — generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'

# Disable automatic sample data seeding in production
JTA_AUTO_SEED=false

# -----------------------------------------------------------------------------
# Database (PostgreSQL + PostGIS required for production)
# -----------------------------------------------------------------------------
JTA_DATABASE_URL=postgresql+psycopg://judgetracker:CHANGEME@db.example.com:5432/judgetracker

# -----------------------------------------------------------------------------
# CORS (HTTPS only, no wildcards in production)
# -----------------------------------------------------------------------------
JTA_CORS_ORIGINS=https://yourdomain.example.com

# -----------------------------------------------------------------------------
# Admin Features
# -----------------------------------------------------------------------------
# Shared admin tokens are legacy compatibility only (local/dev). These feature
# flags are token-guarded and should remain disabled in JWT-only production.
JTA_ENABLE_ADMIN_IMPORTS=false
JTA_ENABLE_ADMIN_REVIEW=false
# Optional legacy-only values (do not use in production JWT deployments):
# JTA_ADMIN_TOKEN=
# JTA_ADMIN_REVIEW_TOKEN=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Use Redis for multi-instance deployments
JTA_RATE_LIMIT_BACKEND=redis
JTA_REDIS_URL=redis://redis.internal:6379/0
# Set to your load-balancer / reverse-proxy IP(s)
JTA_TRUSTED_PROXY_IPS=10.0.0.1

# -----------------------------------------------------------------------------
# Evidence Store (filesystem storage for large content)
# REQUIRED in production — startup will exit(1) if not set.
# -----------------------------------------------------------------------------
JTA_EVIDENCE_STORE_ROOT=/data/judge-evidence
JTA_EVIDENCE_STORE_REQUIRED=true
JTA_EVIDENCE_STORE_PROBE_WRITE=true

# -----------------------------------------------------------------------------
# CourtListener API
# -----------------------------------------------------------------------------
# Docker Compose remaps COURTLISTENER_* → JTA_COURTLISTENER_*; use the JTA_ form
# when connecting directly without Docker Compose (e.g. bare-metal or k8s).
COURTLISTENER_API_TOKEN=CHANGEME
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4
JTA_COURTLISTENER_API_TOKEN=CHANGEME
JTA_COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=https://yourdomain.example.com
BACKEND_INTERNAL_URL=http://backend:8000
