# =============================================================================
# JudgeTracker Atlas - Environment Configuration
# =============================================================================
# Copy this file to .env and modify values as needed for your environment.
# For local development, the defaults below should work out of the box.
# =============================================================================

# Application environment: development | staging | production
JTA_APP_ENV=development

# Enable sample data seeding in development (set to false in production)
JTA_AUTO_SEED=true

# Admin features (disabled by default in production — must be explicitly enabled)
# SECURITY: Set JTA_ENABLE_ADMIN_IMPORTS=false and JTA_ENABLE_ADMIN_REVIEW=false in production
# unless you have proper auth controls in place.
JTA_ENABLE_ADMIN_IMPORTS=true
JTA_ENABLE_ADMIN_REVIEW=true
# SECURITY: Replace these tokens with long random secrets in production.
# All admin endpoints return 403 if these are empty or the feature flags are false.
JTA_ADMIN_TOKEN=dev-token-change-in-production
JTA_ADMIN_REVIEW_TOKEN=dev-token-change-in-production

# -----------------------------------------------------------------------------
# CourtListener API (optional for local development)
# -----------------------------------------------------------------------------
# Get a token at https://www.courtlistener.com/api/rest-info/
# Leave empty to skip CourtListener ingestion in local development
COURTLISTENER_API_TOKEN=
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4
# For direct backend development (without Docker Compose), use the JTA_-prefixed form;
# Docker Compose remaps COURTLISTENER_* → JTA_COURTLISTENER_* automatically.
# JTA_COURTLISTENER_API_TOKEN=
# JTA_COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4

# Evidence store (optional; only needed when storing large snapshot content outside the DB)
# JTA_EVIDENCE_STORE_ROOT=

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For Docker Compose: uses the postgres service
# For direct local dev: uses localhost PostgreSQL
JTA_DATABASE_URL=postgresql+psycopg://judgetracker:judgetracker@localhost:5432/judgetracker

# -----------------------------------------------------------------------------
# CORS Origins
# -----------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins
# Include both Docker and direct local dev URLs
JTA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
BACKEND_INTERNAL_URL=http://backend:8000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Backend: "memory" (single-process) or "redis" (multi-process/multi-instance)
JTA_RATE_LIMIT_BACKEND=memory
# JTA_REDIS_URL=redis://localhost:6379/0
# PRODUCTION SAFETY: memory rate limiting is rejected at startup in production unless this flag is set.
# Only set to true for verified single-node, single-worker deployments. Never for multi-replica setups.
# JTA_ALLOW_IN_MEMORY_RATE_LIMIT_PRODUCTION=true
# Comma-separated list of trusted proxy IPs whose X-Forwarded-For is trusted
JTA_TRUSTED_PROXY_IPS=
